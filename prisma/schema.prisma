generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Profil de base (infos permanentes)
model Profile {
  id        String   @id @default(cuid())
  name      String   @default("Profil Base") // Le nom du variant
  isDefault Boolean  @default(false)
  fullName  String
  title     String   // ex: "Digital Product Manager"
  photo     String?  // URL de l'image
  motto     String?  // Phrase d'accroche
  email     String
  phone     String
  location  String
  website   String?
  linkedin  String?
  summary   String   @db.Text // "À propos de moi"
  interests String?  // Liste séparée par des tirets
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  skills         Skill[]
  experiences    Experience[]
  education      Education[]
  certifications Certification[]
  languages      Language[]
  customSections ProfileSection[]
  applications   Application[]
}

model ProfileSection {
  id        String  @id @default(cuid())
  title     String  // ex: "Logiciels", "Distinctions"
  icon      String? // Lucide icon name
  content   String  @db.Text
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  order     Int     @default(0)
}

model Skill {
  id        String  @id @default(cuid())
  category  String  // ex: "Vision produit & stratégie"
  items     String  @db.Text // Compétences séparées par des virgules
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  order     Int     @default(0)
}

model Experience {
  id        String    @id @default(cuid())
  jobTitle  String
  company   String
  location  String
  startDate String    // ex: "Juil. 2023"
  endDate   String?   // null = "Aujourd'hui"
  profileId String
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  order     Int       @default(0)
  missions  Mission[]
}

model Mission {
  id            String     @id @default(cuid())
  clientName    String     // ex: "Compagnie Ivoirienne d'Électricité (CIE)"
  clientCountry String?    // ex: "Côte d'Ivoire"
  bullets       String     @db.Text // JSON array de strings
  experienceId  String
  experience    Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  order         Int        @default(0)
}

model Education {
  id        String  @id @default(cuid())
  degree    String
  school    String
  location  String
  date      String
  details   String? // spécialisation
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  order     Int     @default(0)
}

model Certification {
  id        String  @id @default(cuid())
  name      String
  issuer    String
  date      String
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  order     Int     @default(0)
}

model Language {
  id        String  @id @default(cuid())
  name      String
  level     String  // ex: "Natif", "Avancé (B2+)"
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// Candidatures
model Application {
  id             String    @id @default(cuid())
  jobTitle       String
  company        String
  jobUrl         String?   @db.Text
  jobDescription String?   @db.Text
  status         String    @default("draft") // draft | applied | interview | rejected | offer
  appliedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  baseProfileId  String?
  baseProfile    Profile?  @relation(fields: [baseProfileId], references: [id], onDelete: SetNull)

  // CV adapté
  adaptedSummary String? @db.Text
  adaptedSkills  String? @db.Text // JSON
  adaptedBullets String? @db.Text // JSON
  atsScore       Int?    // 0-100
  atsKeywords    String? @db.Text // JSON

  // Lettre de motivation
  coverLetter String? @db.Text

  notes String? @db.Text
}
